# Copia este archivo como .env y completa los valores.

# Secreto para firmar sesiones (JWT). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="reemplaza-con-un-secreto-largo-aleatorio"

# Base de datos PostgreSQL (Neon). Cópiala desde el panel de Neon (connection string).
DATABASE_URL="postgresql://usuario:password@host.neon.tech/dbname?sslmode=require"

# Usuario administrador inicial que crea el seed (npm run db:seed)
ADMIN_EMAIL="admin@girD.gob.ec"
ADMIN_PASSWORD="cambia-esta-clave"
